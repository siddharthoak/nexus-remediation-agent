# Copy to .env and fill in every value before running the Fixer container locally.
# .env is gitignored — never commit it.
#
# Used by: `podman run --env-file .env ...` / `docker run --env-file .env ...`
# See TESTING_PODMAN.md section 5 / TESTING_DOCKER.md section 5 for the Fixer-only
# walkthrough, or section 6 of either file for the full Fixer + Watcher pipeline
# (which needs the optional Cosmos block below too).

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_TARGET=org/repo-name        # owner/repo of the repo to remediate
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx     # PAT with repo + pull_request scopes (needed even
                                         # if your own local clone uses SSH — the Fixer
                                         # container always clones/pushes over HTTPS)

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxx
MODEL_DEPLOYMENT_NAME=claude-sonnet-5   # Fixer's model; Knowledge Agent defaults to
                                         # claude-haiku-4-5-20251001 if unset

# ── Vulnerability source (Section 4.4a in PLAN.md) ───────────────────────────
DEPLOYMENT_MODE=local                   # local = ScanReportClient (Trivy/Grype/OWASP JSON) +
                                         #         InMemory tracking/KB store;
                                         # azure = NexusIQClient (real Nexus IQ Server) +
                                         #         Cosmos-backed tracking/KB store.
                                         # Leave this BLANK (not "local") if you're doing the
                                         # section-6 Fixer+Watcher test below — that needs
                                         # ScanReportClient (no NEXUS_IQ_ENDPOINT set) together
                                         # with the Cosmos store (COSMOS_ENDPOINT set), and
                                         # DEPLOYMENT_MODE=local forces InMemory regardless of
                                         # COSMOS_ENDPOINT.
SCAN_REPORT_PATH=/reports                # path INSIDE the container (bind-mount your local
                                         # scan-reports directory here, e.g. -v ./scan-reports:/reports)

# ── Agent settings ────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
MAX_PARALLEL_FIXES=5

# ── Cosmos DB — ONLY needed for the section-6 Fixer+Watcher shared-state test ──
# Fixer and Watcher run as separate container invocations; InMemoryTrackingStore/
# InMemoryKBStore are per-process, so the Watcher can never see a PR the Fixer just
# opened unless both point at the same persistent backend. The only backend this
# codebase supports is Azure Cosmos DB (CosmosTrackingStore/CosmosKBStore in
# agents/common/) — a real (dev/test is fine) Cosmos account, not the Cosmos
# Emulator, which doesn't work here (see note below).
# Leave these blank to skip section 6 and only run the Fixer in isolation (section 5).
COSMOS_ENDPOINT=                         # e.g. https://<account>.documents.azure.com:443/
COSMOS_DATABASE=oss-remediation          # default used by tracking_store.py if unset
COSMOS_CONTAINER=tracking-records        # default used by tracking_store.py if unset
COSMOS_KB_CONTAINER=kb-entries           # default used by knowledge_store.py if unset

# ── Watcher-only ────────────────────────────────────────────────────────────
# AafFixerInvoker (agents/watcher/retry_gate.py) reads this eagerly at Watcher
# startup whenever an open remediation PR exists, even locally — set it to any
# placeholder value so the Watcher doesn't crash with a KeyError before it can
# even check CI status. It is never actually used unless FIXER_AGENT_ID points at
# a real Azure AI Foundry Hosted Agent (production only) — see section 6 for why
# the automatic Watcher→Fixer retry hand-off can't be exercised locally today.
FIXER_AGENT_ID=local-placeholder
CI_POLL_INTERVAL=30                      # seconds between CI status polls (default shown)
CI_TIMEOUT_SECONDS=1800                  # give up waiting for CI after this long (default shown)
